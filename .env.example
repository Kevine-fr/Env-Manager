# ============================================================================
# Configuration ENV Manager — copiez ce fichier en .env et adaptez les valeurs.
# (Ce .env-ci est celui de l'application elle-même, pas un projet scanné.)
# ============================================================================

# --- Sécurité (OBLIGATOIRE) ---
# Mot de passe de l'admin (le seul autorisé à voir/éditer/supprimer).
ADMIN_PASSWORD=change-moi-vite
ADMIN_USERNAME=admin
# Clé de signature des jetons. Générez-la : openssl rand -hex 32
JWT_SECRET=remplacez-par-une-cle-aleatoire-de-32-caracteres-minimum
JWT_EXPIRE_HOURS=12

# --- Dossier à scanner ---
# En exécution directe sur le VPS : /home/kevine/deploy
# En Docker : laissez /deploy (le dossier est monté via docker-compose).
DEPLOY_ROOT=/deploy

# --- Planification ---
SCAN_INTERVAL_MINUTES=30
SCAN_ON_STARTUP=true

# --- Détection des fichiers .env ---
# Motifs considérés comme des .env (séparés par des virgules).
ENV_GLOBS=.env,.env.*
# Suffixes ignorés (templates sans vrais secrets).
ENV_EXCLUDE_SUFFIXES=.example,.sample,.dist,.template
# Dossiers ignorés lors du parcours récursif.
EXCLUDE_DIRS=node_modules,vendor,.git,dist,build,__pycache__,.venv,venv,storage

# --- Serveur ---
HOST=0.0.0.0
PORT=8000

# Emplacement du JSON généré (laissez vide pour ./data).
# DATA_DIR=/app/data

# ============================================================================
# MODULE INFRASTRUCTURE (contrôle Docker, nginx, SSL, git push)
# ============================================================================
# Active/désactive tout le module.
INFRA_ENABLED=true

# Domaine de base : les sous-domaines deviennent <sous-domaine>.<APP_DOMAIN>.
APP_DOMAIN=wk-archi-o22a-15m-g1.fr

# Racine du dossier deploy côté HÔTE (= source du montage Docker, identique à
# DEPLOY_HOST_PATH). Indispensable pour que certbot (conteneur frère) monte les
# bons chemins de l'hôte.
DEPLOY_HOST_ROOT=/home/kevine/deploy

# Chemin du dépôt Infrastructure tel que vu par env-manager (sous /deploy).
# Laissez vide pour auto-détecter le dossier contenant nginx/conf.d.
# Exemple si le dépôt est /home/kevine/deploy/Infrastructure : /deploy/Infrastructure
INFRA_REPO_PATH=

# Services Docker pilotables depuis l'UI (liste blanche, séparés par des virgules).
INFRA_SERVICES=sonarqube

# Conteneur nginx à recharger, et emplacements (relatifs au dépôt).
NGINX_CONTAINER=nginx
# NGINX_CONF_SUBDIR=nginx/conf.d
# CERTBOT_WWW_SUBDIR=certbot/www
# CERTBOT_CONF_SUBDIR=certbot/conf
# CERTBOT_IMAGE=certbot/certbot:latest

# --- Git : commit + push du dépôt Infrastructure ---
GIT_BRANCH=main
GIT_REMOTE=origin
GIT_AUTHOR_NAME=ENV Manager
GIT_AUTHOR_EMAIL=env-manager@vps.local
# Pousser automatiquement après chaque modif (.conf, SSL) ?
INFRA_AUTO_PUSH=true
#
# Authentification du push — CHOISISSEZ UNE des deux méthodes :
#
# (A) Token GitHub (HTTPS) — le plus simple. Créez un token à portée "repo"
#     (fine-grained : Contents = Read/Write) et renseignez le slug du dépôt.
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GIT_REPO_SLUG=Kevine-fr/Infrastructure
#
# (B) Clé SSH de déploiement — montez la clé privée dans le conteneur
#     (voir docker-compose.yml) et pointez dessus :
# GIT_SSH_KEY_PATH=/keys/deploy_key
